{
  "name": "@kanwas/execenv",
  "version": "2.0.0",
  "description": "Execution environment for AI agent with file watching and Yjs server sync",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sentry/node": "^10.32.0",
    "chokidar": "^4.0.3",
    "diff3": "^0.0.4",
    "pino": "^10.1.0",
    "shared": "workspace:*",
    "valtio": "2.2.0",
    "ws": "^8.18.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@blocknote/server-util": "^0.41.1",
    "@types/diff3": "^0.0.2",
    "@types/node": "^20.10.0",
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.5.10",
    "e2b": "^2.14.1",
    "pino-pretty": "^13.1.2",
    "pngjs": "^7.0.0",
    "typescript": "^5.3.0",
    "valtio-y": "https://github.com/Ryner01/valtio-y/releases/download/v1.1.4/valtio-y-1.1.4.tgz",
    "vitest": "^2.1.0",
    "yjs": "^13.6.27"
