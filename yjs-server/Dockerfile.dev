# Development Dockerfile for yjs-server
# Build context must be the repo root (see docker-compose.yml)
FROM node:22-slim

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Workspace manifests + patches so pnpm can resolve the locked graph
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY patches/ ./patches/
COPY shared/package.json ./shared/
COPY yjs-server/package.json ./yjs-server/

# Install yjs-server + its workspace deps (shared) using the frozen lockfile
RUN HUSKY=0 pnpm install --frozen-lockfile --filter kanwas-yjs-server...

# Build shared so yjs-server can import from shared/dist at runtime (tsx resolves exports map)
COPY shared ./shared
RUN pnpm --filter shared build

# Copy yjs-server source
COPY yjs-server ./yjs-server

WORKDIR /app/yjs-server

# node --watch (used by `pnpm dev`) crashes if a file passed to --env-file-if-exists
# is missing, because it still adds it to the watch set. Create an empty one.
RUN touch .env.local

EXPOSE 1999

CMD ["pnpm", "run", "dev"]
