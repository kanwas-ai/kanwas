# =============================================================================
# KANWAS BACKEND ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and update values as needed for your environment.

# =============================================================================
# APPLICATION
# =============================================================================
TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
APP_KEY=generate-with-node-ace-generate-key
APP_NAME=kanwas
NODE_ENV=development

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
# Use DATABASE_URL for single connection string, OR individual DB_* variables
# DATABASE_URL=postgresql://user:password@host:port/database
DB_HOST=localhost
DB_PORT=5432
DB_USER=kanwas
DB_PASSWORD=kanwas
DB_DATABASE=kanwas

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# AI SERVICES
# =============================================================================
# Anthropic (LLM provider - required)
ANTHROPIC_API_KEY=sk-ant-...

# Composio (agent tool integrations - required)
COMPOSIO_API_KEY=ak_...

# Groq (voice transcription - optional)
GROQ_API_KEY=gsk_...

# Parallel (web search - required)
PARALLEL_API_KEY=your-parallel-api-key

# Jina AI (optional - for document processing)
JINA_API_KEY=jina_...

# Sentry (optional)
SENTRY_DSN=

# Slack webhook (optional - waitlist and user registration notifications)
SLACK_WEBHOOK_URL=

# PostHog private query API (optional for org usage limits)
POSTHOG_QUERY_API_KEY=

# =============================================================================
# AUTHENTICATION
# =============================================================================
# API Secret for Yjs server authentication
API_SECRET=change-me-shared-with-yjs-server

# Google OAuth (optional for local dev)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3333/auth/google/callback

# =============================================================================
# YJS SERVER
# =============================================================================
# Yjs server for real-time collaboration
YJS_SERVER_HOST=localhost:1999
YJS_SERVER_PROTOCOL=ws

# =============================================================================
# SANDBOX (E2B)
# =============================================================================
# Used when SANDBOX_PROVIDER=e2b (production/staging sandboxes)
# Set this same variable key per environment with different values
# (e.g. staging -> kanwas-execenv-staging, production -> kanwas-execenv-prod)
SANDBOX_E2B_TEMPLATE_ID=kanwas-execenv-staging

# =============================================================================
# FILE STORAGE
# =============================================================================
# Options: fs (local filesystem), r2 (Cloudflare R2)
DRIVE_DISK=fs

# Cloudflare R2 (required if DRIVE_DISK=r2)
R2_KEY=your-r2-access-key-id
R2_SECRET=your-r2-secret-access-key
R2_BUCKET=your-r2-bucket-name
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

AI_GATEWAY_API_KEY=
ASSEMBLYAI_API_KEY=
ANTHROPIC_API_KEY=

