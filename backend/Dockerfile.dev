# Development Dockerfile for backend
# Build context must be the repo root (see docker-compose.yml)
FROM node:22-slim

RUN apt-get update && apt-get install -y git openssh-client && rm -rf /var/lib/apt/lists/* && \
    corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Workspace manifests + patches so pnpm can resolve the locked graph
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY patches/ ./patches/
COPY shared/package.json ./shared/
COPY backend/package.json ./backend/

# Install backend + its workspace deps (shared) using the frozen lockfile
RUN HUSKY=0 pnpm install --frozen-lockfile --filter backend...

# Build shared so backend can import from shared/dist at runtime
COPY shared ./shared
RUN pnpm --filter shared build

# Copy backend source
COPY backend ./backend

WORKDIR /app/backend

EXPOSE 3333

CMD pnpm run migrate && pnpm run dev
