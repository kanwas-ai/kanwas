{
  "name": "@kanwas/cli",
  "version": "0.1.4",
  "description": "CLI tool for syncing local directories with Kanwas workspaces",
  "type": "module",
  "bin": {
    "kanwas": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@blocknote/core": "^0.46.0",
    "@blocknote/server-util": "^0.46.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "image-size": "^2.0.2",
    "lib0": "^0.2.114",
    "picomatch": "^4.0.3",
    "pngjs": "^7.0.0",
    "socket.io-client": "^4.8.1",
    "valtio": "2.2.0",
    "valtio-y": "https://github.com/Ryner01/valtio-y/releases/download/v1.1.4/valtio-y-1.1.4.tgz",
    "ws": "^8.18.0",
    "y-protocols": "^1.0.6",
    "yaml": "^2.8.1",
    "yjs": "^13.6.27",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "@types/picomatch": "^4.0.2",
    "@types/ws": "^8.18.1",
    "shared": "workspace:*",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "~5.7.3"
  }
